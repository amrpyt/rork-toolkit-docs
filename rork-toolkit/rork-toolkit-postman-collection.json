	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Helper function to clean base64 images",
					"function cleanBase64(dataUri) {",
					"  return dataUri.replace(/^data:.*?;base64,/, '');",
					"}",
					"",
					"// Set cleaned base64 if raw version exists",
					"if (pm.environment.get('base64_image_raw')) {",
					"  const cleaned = cleanBase64(pm.environment.get('base64_image_raw'));",
					"  pm.environment.set('base64_image_clean', cleaned);",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "RORK_BASE_URL",
			"value": "https://toolkit.rork.com",
			"type": "string"
		},
		{
			"key": "EXPO_PUBLIC_TOOLKIT_URL",
			"value": "https://toolkit.rork.com",
			"type": "string"
		}
	]
}
