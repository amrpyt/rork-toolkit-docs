{
	"info": {
		"_postman_id": "rork-toolkit-api-collection",
		"name": "Rork Toolkit API Collection",
		"description": "Complete API collection for Rork Toolkit AI endpoints\n\n**Setup Instructions:**\n1. Set environment variable `RORK_BASE_URL` = `https://toolkit.rork.com`\n2. For Agent Chat, set `EXPO_PUBLIC_TOOLKIT_URL` = `https://toolkit.rork.com`\n3. Replace `{{base64_image_clean}}` with actual base64 string (WITHOUT data URI prefix)\n4. Replace `{{audio_file}}` with actual audio file for STT\n\n**Important Notes:**\n- Images must be base64 encoded WITHOUT `data:image/jpeg;base64,` prefix\n- STT endpoint uses multipart/form-data (Postman handles automatically)\n- No API key required - authentication is platform-managed",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Text LLM with Vision (Primary)",
			"item": [
				{
					"name": "Text Only Generation",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a creative story about a robot learning to paint\"\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{RORK_BASE_URL}}/text/llm/",
							"host": [
								"{{RORK_BASE_URL}}"
							],
							"path": [
								"text",
								"llm",
								""
							]
						}
					}
				},
				{
					"name": "Image Analysis + JSON Output",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Analyze this meal image and return nutrition info as JSON with fields: name, calories, protein, carbs, fats, description\"\n        },\n        {\n          \"type\": \"image\",\n          \"image\": \"{{base64_image_clean}}\"\n        }\n      ]\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{RORK_BASE_URL}}/text/llm/",
							"host": [
								"{{RORK_BASE_URL}}"
							],
							"path": [
								"text",
								"llm",
								""
							]
						}
					}
				},
				{
					"name": "With Optional Parameters",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful AI assistant specialized in creative writing.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a short poem about technology and nature\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 200,\n  \"top_p\": 0.9\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{RORK_BASE_URL}}/text/llm/",
							"host": [
								"{{RORK_BASE_URL}}"
							],
							"path": [
								"text",
								"llm",
								""
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Agent Chat (SDK-oriented)",
			"item": [
				{
					"name": "Simple Chat Message",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"messages\": [\n    {\n      \"id\": \"msg_001\",\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Hello, how can you help me today?\"\n        }\n      ]\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{EXPO_PUBLIC_TOOLKIT_URL}}/agent/chat",
							"host": [
								"{{EXPO_PUBLIC_TOOLKIT_URL}}"
							],
							"path": [
								"agent",
								"chat"
							]
						}
					}
				},
				{
					"name": "Chat with Tools",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"messages\": [\n    {\n      \"id\": \"msg_001\",\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Add a todo to buy groceries\"\n        }\n      ]\n    }\n  ],\n  \"tools\": {\n    \"addTodo\": {\n      \"description\": \"Add a new todo item to the list\",\n      \"parameters\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"title\": {\n            \"type\": \"string\",\n            \"description\": \"Title of the todo item\"\n          },\n          \"priority\": {\n            \"type\": \"string\",\n            \"enum\": [\"low\", \"medium\", \"high\"],\n            \"description\": \"Priority level of the todo\"\n          },\n          \"dueDate\": {\n            \"type\": \"string\",\n            \"description\": \"Due date in YYYY-MM-DD format\"\n          }\n        },\n        \"required\": [\"title\"]\n      }\n    }\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{EXPO_PUBLIC_TOOLKIT_URL}}/agent/chat",
							"host": [
								"{{EXPO_PUBLIC_TOOLKIT_URL}}"
							],
							"path": [
								"agent",
								"chat"
							]
						}
					}
				}
			]
		},
