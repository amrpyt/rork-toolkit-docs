{
  "info": {
    "_postman_id": "6fa29c18-3ce8-4db1-a1d8-rorktoolkit2026",
    "name": "Rork Toolkit API — Unofficial Current Reference",
    "description": "Evidence-based requests for current and legacy Rork Toolkit endpoints. Not an official Rork collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://toolkit.rork.com",
      "type": "string"
    },
    {
      "key": "imageBase64",
      "value": "REPLACE_WITH_BASE64",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Current — Text",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Reply exactly POSTMAN_TEXT_OK\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/llm/text",
          "host": ["{{baseUrl}}"],
          "path": ["llm", "text"]
        },
        "description": "Current text endpoint used by the published SDK."
      }
    },
    {
      "name": "Current — Structured Object",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Return Alice, age 30\"\n    }\n  ],\n  \"schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"name\": { \"type\": \"string\" },\n      \"age\": { \"type\": \"number\" }\n    },\n    \"required\": [\"name\", \"age\"],\n    \"additionalProperties\": false\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/llm/object",
          "host": ["{{baseUrl}}"],
          "path": ["llm", "object"]
        },
        "description": "Validate the returned object locally even when the response is HTTP 200."
      }
    },
    {
      "name": "Current — Agent Text Stream",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"id\": \"postman-user-1\",\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Reply exactly POSTMAN_AGENT_OK\"\n        }\n      ]\n    }\n  ],\n  \"tools\": {}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/agent/chat",
          "host": ["{{baseUrl}}"],
          "path": ["agent", "chat"]
        },
        "description": "Returns Vercel AI SDK UI Message Stream v1 data frames."
      }
    },
    {
      "name": "Current — Agent Tool Call",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\n      \"id\": \"postman-user-tool-1\",\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Use lookup_order to check order ORD-42\"\n        }\n      ]\n    }\n  ],\n  \"tools\": {\n    \"lookup_order\": {\n      \"description\": \"Look up an order by ID\",\n      \"jsonSchema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"orderId\": { \"type\": \"string\" }\n        },\n        \"required\": [\"orderId\"],\n        \"additionalProperties\": false\n      }\n    }\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/agent/chat",
          "host": ["{{baseUrl}}"],
          "path": ["agent", "chat"]
        },
        "description": "Look for tool-input-available and finishReason tool-calls."
      }
    },
