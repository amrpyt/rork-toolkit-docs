				{
					"name": "Transcribe Audio - Specific Language",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "audio",
									"description": "Audio file to transcribe",
									"type": "file",
									"src": []
								},
								{
									"key": "language",
									"value": "en",
									"description": "Language code (e.g., en, ar, es, fr)",
									"type": "text"
								}
