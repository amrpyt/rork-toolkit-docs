		{
			"name": "5. Speech-to-Text (STT)",
			"item": [
				{
					"name": "Transcribe Audio - Auto Language",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "audio",
									"description": "Audio file to transcribe (mp3, mp4, mpeg, mpga, m4a, wav, webm)",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{RORK_BASE_URL}}/stt/transcribe/",
							"host": [
								"{{RORK_BASE_URL}}"
							],
							"path": [
