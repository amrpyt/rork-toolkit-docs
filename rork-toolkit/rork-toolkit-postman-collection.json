        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"Change the background to a modern office\",\n  \"images\": [\n    {\n      \"type\": \"image\",\n      \"image\": \"{{imageBase64}}\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/images/edit/",
          "host": ["{{baseUrl}}"],
          "path": ["images", "edit", ""]
        }
      }
    },
    {
